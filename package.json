{
  "name": "obi-tool",
  "version": "1.4.8",
  "description": "マイソク業者情報削除ツール",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "build:signed": "electron-builder --win --publish never",
    "build:publish": "electron-builder --win --publish always"
  },
  "author": "obichan",
  "license": "MIT",
  "devDependencies": {
    "electron": "28.3.3",
    "electron-builder": "^24.9.1",
    "pdfjs-dist": "^3.11.174"
  },
  "build": {
    "appId": "com.obichan.obi-tool",
    "productName": "Obi-Tool",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "device-id.js",
      "license-manager.js",
      "app/**/*",
      "assets/**/*",
      "node_modules/multilingual-purejs-ocr/**/*",
      "node_modules/onnxruntime-common/**/*",
      "node_modules/onnxruntime-node/**/*"
    ],
    "asarUnpack": [
      "node_modules/onnxruntime-node/**/*",
      "node_modules/multilingual-purejs-ocr/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "fileAssociations": [
        {
          "ext": "pdf",
          "name": "PDF Document",
          "description": "PDF Document",
          "role": "Viewer"
        }
      ]
    },
    "artifactName": "${productName}.Setup.${version}.${ext}",
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Obi-Tool"
    },
    "publish": {
      "provider": "github",
      "owner": "najimi0219",
      "repo": "obi-tool-app"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "jsqr": "^1.4.0",
    "multilingual-purejs-ocr": "^1.0.1"
  }
}
